#!/usr/bin/env bash

set -e

is_git_directory() {
  printf "$1;$(cd $1; git rev-parse --is-inside-work-tree)\n"
}

get_workflows() {
  local filename=$1
  find "$filename" -mindepth 1 -maxdepth 1 -type d -exec bash -c 'for pathname do is_git_directory "$pathname"; done' bash {} + \
    | grep ";true" | sed "s/;true//"
}


main() {
  local selected=""

  if [[ $# -eq 1 ]]; then
      selected=$1
  else
    personal=$(find ~/.dotfiles ~/Projects/private/computer-enhance \
      ~/Projects/private/zig \
      ~/Projects/private/clojure \
      ~/Projects/private/xcode \
      ~/Projects/private/go \
      ~/Projects/private/rails \
      -mindepth 1 -maxdepth 1 -type d -not -iwholename '*.git')

    local hai_workflows=$(get_workflows ~/Projects/humbleai/hai)
    selected=$(printf "${personal}\n${hai_workflows}" | fzf)
  fi

  if [[ -z $selected ]]; then
      exit 0
  fi

  local selected_root_name=$(basename "$(dirname "$selected")" | tr . _)
  local selected_name=$(basename "$selected" | tr . _)
  local session_name="$selected_root_name/$selected_name"

  # Check if tmux is running
  local tmux_running
  tmux_running=$(pgrep tmux || true)

  # If not in tmux and tmux is not running, create new session
  if [[ -z "${TMUX:-}" ]] && [[ -z "$tmux_running" ]]; then
      tmux new-session -s "$session_name" -c "$selected"
      exit 0
  fi

  # Check if session already exists
  if ! tmux has-session -t="$session_name" 2>/dev/null; then
      # Create new detached session
      tmux new-session -ds "$session_name" -c "$selected"
  fi

  # Switch to the session (only if we're inside tmux)
  if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$session_name"
  else
      # If tmux is running but we're not in it, attach to the session
      tmux attach-session -t "$session_name"
  fi
}

export -f is_git_directory

main "$@"
